{
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "tools": {
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow"
  },
  "bash": {
    "gh issue view *": "allow",
    "gh pr view *": "allow",
    "gh pr diff *": "allow",
    "git status *": "allow",
    "git diff *": "allow",
    "git log *": "allow"
  }
}
